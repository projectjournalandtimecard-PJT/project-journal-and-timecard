{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "pjt-local-storage",
  "windows": ["main"],
  "permissions": [
    { "identifier": "fs:allow-mkdir",           "allow": [{ "path": "$APPLOCALDATA" }, { "path": "$APPLOCALDATA/**" }] },
    { "identifier": "fs:allow-exists",          "allow": [{ "path": "$APPLOCALDATA" }, { "path": "$APPLOCALDATA/**" }] },
    { "identifier": "fs:allow-read-dir",        "allow": [{ "path": "$APPLOCALDATA" }, { "path": "$APPLOCALDATA/**" }] },
    { "identifier": "fs:allow-read-text-file",  "allow": [{ "path": "$APPLOCALDATA/**" }] },
    { "identifier": "fs:allow-write-text-file", "allow": [{ "path": "$APPLOCALDATA/**" }] },
    { "identifier": "fs:allow-remove",          "allow": [{ "path": "$APPLOCALDATA/**" }] }
  ]
}
